{
  "redirects": [
    {
      "source": "/social-media",
      "destination": "/social-media-lima.html",
      "permanent": true
    },
    {
      "source": "/diseno-web",
      "destination": "/diseno-web-lima.html",
      "permanent": true
    },
    {
      "source": "/branding",
      "destination": "/branding-lima.html",
      "permanent": true
    },
    {
      "source": "/produccion-audiovisual",
      "destination": "/produccion-audiovisual-lima.html",
      "permanent": true
    },
    {
      "source": "/portafolio",
      "destination": "/#portafolio",
      "permanent": false
    },
    {
      "source": "/servicios",
      "destination": "/#services",
      "permanent": false
    },
    {
      "source": "/blog",
      "destination": "/#blog",
      "permanent": false
    },
    {
      "source": "/agencia-marketing-lima",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/agencia-redes-sociales",
      "destination": "/social-media-lima.html",
      "permanent": true
    },
    {
      "source": "/agencia-seo-lima",
      "destination": "/seo-local-lima.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}